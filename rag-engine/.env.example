# ─────────────────────────────────────────────
# BASE DE DONNÉES (partagée avec ingestion)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://raguser:ragpassword@localhost:5432/ragdb
DB_POOL_MAX=20

# ─────────────────────────────────────────────
# REDIS (cache embeddings + sessions)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# OLLAMA
# ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=qwen3:4b        # ou qwen3:14b, gemma3:9b, mistral:7b

# ─────────────────────────────────────────────
# RAG TUNING
# ─────────────────────────────────────────────
CANDIDATE_POOL=40          # Chunks récupérés avant re-ranking
CONTEXT_CHUNKS=6           # Chunks envoyés au LLM
HISTORY_WINDOW=6           # Nb messages historique dans le prompt
SUMMARY_TOKEN_THRESHOLD=6000  # Tokens avant résumé auto

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
